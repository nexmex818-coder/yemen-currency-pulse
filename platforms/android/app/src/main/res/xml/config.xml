<?xml version='1.0' encoding='utf-8'?>
<widget id="com.aden.live.v13" version="13.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>نبض الصرف</name>
    <description>تطبيق أسعار الصرف في اليمن</description>
    <author email="dev@aden.com">Aden Dev</author>
    <content src="index.html" />
    <access origin="*" />
    <allow-navigation href="*" />
    <allow-intent href="*" />
    <preference name="loglevel" value="DEBUG" />
    <preference name="BackgroundColor" value="#121212" />
    <preference name="Orientation" value="portrait" />
    <preference name="AndroidInsecureHttpRequestsAllow" value="true" />
</widget>
